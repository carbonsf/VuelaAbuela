# Host of the deployed PartyServer worker (no protocol). Used by PartyTransport.
VITE_PARTYKIT_HOST=vuela-abuela.davidmgoehring.workers.dev

# Transport mode. Default (unset / anything but "false") = god-mode: single
# browser harness, in-memory transport, no backend needed. Set to "false" to run
# the REAL multi-device flow (teacher creates a room, students join their own
# devices) against VITE_PARTYKIT_HOST.
#   VITE_GOD_MODE=false   # real PartyKit mode
